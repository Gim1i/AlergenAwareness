        <ui:Slider value="42" high-value="100" name="Master_Slider" class="Larger-Slider" style="flex-grow: 0; flex-shrink: 0; height: 100%; align-self: auto; width: 62%; min-width: initial; max-width: initial; align-items: center;" />
    </ui:VisualElement>
